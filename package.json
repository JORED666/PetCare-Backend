{
  "name": "petcare-backend",
  "version": "1.0.0",
  "description": "Backend microservicios",
  "private": true,
  "workspaces": [
    "services/*",
    "shared"
  ],
  "scripts": {
    "dev:gateway": "npx ts-node -e \"require('./src/server.ts')\" || npx ts-node src/server.ts",
    "gateway": "node -r ts-node/register src/server.ts",
    "start:gateway": "node dist/gateway.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
